---
import { Icon } from 'astro-icon/components';

interface Props {
  verb: string;
  objectName?: string | undefined;
  objectUrl?: string | undefined;
  /** 'compact' for feed cards, 'large' for detail views */
  size?: 'compact' | 'large';
}

const { verb, objectName, objectUrl, size = 'compact' } = Astro.props;

const emojiMap: Record<string, string> = {
  watch: '📺', read: '📚', listen: '🎧', play: '🎮',
};
const labelMap: Record<string, string> = {
  watch: 'Watched', read: 'Read', listen: 'Listened to', play: 'Played',
};

const emoji = emojiMap[verb] ?? '';
const label = labelMap[verb] ?? verb;
---

<div class={`callout--${size}`}>
  <span aria-hidden="true">{emoji}</span>
  <span>
    {label}{' '}
    {objectUrl ? (
      <a href={objectUrl} class={`u-${verb}-of`} rel="noopener" target="_blank">
        {objectName ?? objectUrl}
        <Icon name="external-link" aria-hidden="true" />
      </a>
    ) : (
      <strong class={`p-${verb}-of`}>{objectName}</strong>
    )}
  </span>
</div>

<style>
  div {
    display: flex;
    align-items: center;
    background-color: var(--color-surface-2);
    border-radius: var(--radius-md);
    line-height: var(--leading-snug);
  }

  .callout--compact {
    gap: var(--space-2);
    padding: var(--space-3);
    font-size: var(--text-base);
  }

  .callout--large {
    gap: var(--space-3);
    padding: var(--space-4);
    font-size: var(--text-lg);
  }

  /* Emoji */
  div > span:first-child {
    flex-shrink: 0;
  }

  .callout--compact > span:first-child {
    font-size: var(--text-xl);
  }

  .callout--large > span:first-child {
    font-size: var(--text-2xl);
  }

  /* Link */
  a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  a:hover {
    color: var(--color-text-link);
  }

  .callout--compact :global(svg) {
    width: 0.75rem;
    height: 0.75rem;
    color: var(--color-text-tertiary);
  }

  .callout--large :global(svg) {
    width: 0.875rem;
    height: 0.875rem;
    color: var(--color-text-tertiary);
  }
</style>
