---
import { Icon } from 'astro-icon/components';

interface Props {
  replies: Array<{
    authorName?: string | undefined;
    authorUrl?: string | undefined;
    authorPhoto?: string | undefined;
    content?: string | undefined;
    sourceUrl: string;
    sourceLabel: string;
  }>;
}

const { replies } = Astro.props;
---

<div aria-label="Replies">
  <p class="text-sm text-secondary">
    <Icon name="message-square" aria-hidden="true" />
    {replies.length} {replies.length === 1 ? 'reply' : 'replies'}
  </p>
  <ul>
    {replies.map(r => (
      <li>
        {r.authorPhoto && (
          <img src={r.authorPhoto} alt={r.authorName ?? ''} width="36" height="36" />
        )}
        <div>
          <a href={r.authorUrl ?? r.sourceUrl} class="author" rel="noopener" target="_blank">
            {r.authorName ?? r.sourceLabel}
          </a>
          {r.content && (
            <p class="text-sm">{r.content}</p>
          )}
          <a href={r.sourceUrl} class="source text-xs text-secondary" rel="noopener" target="_blank">
            {r.sourceLabel}
          </a>
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  div {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  div > p {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  div > p :global(svg) {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  li {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  li > img {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-full);
    object-fit: cover;
    flex-shrink: 0;
  }

  li > div {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .author {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .author:hover {
    color: var(--color-text-link);
  }

  li p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .source {
    text-decoration: none;
  }

  .source:hover {
    color: var(--color-text-link) !important;
  }
</style>
