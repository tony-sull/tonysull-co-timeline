---
import { Icon } from 'astro-icon/components';
import type { Entry } from '@indiepub/types';
import Markdown from '@indiepub/astro/components/Markdown.astro';
import CardFooter from '../CardFooter.astro';
import { hostname, linkifyHashtags } from '../../lib/format.ts';

interface Props {
  entry: Entry;
  detailUrl: string;
  pubDate: Date;
  badgeLabel?: string | undefined;
}

const { entry, detailUrl, pubDate, badgeLabel } = Astro.props;
const targetUrl = entry.likeOf ?? entry.repostOf ?? entry.inReplyTo;
---

<div>
  <header>
    {badgeLabel && <span class="type-badge">{badgeLabel}</span>}
    {(entry.visibility === 'members' || entry.visibility === 'paid') && (
      <span class="visibility-badge">
        <Icon name="lock" aria-hidden="true" />
        {entry.visibility === 'paid' ? 'Paid' : 'Members'}
      </span>
    )}
    <span class="interaction-verb text-sm text-secondary">
      {entry.type === 'like'   ? 'liked'
      : entry.type === 'repost' ? 'reposted'
      : 'replied to'}
    </span>
  </header>
  {targetUrl && (
    <blockquote>
      <a
        href={targetUrl}
        class:list={[
          entry.likeOf    ? 'u-like-of'    : '',
          entry.repostOf  ? 'u-repost-of'  : '',
          entry.inReplyTo ? 'u-in-reply-to' : '',
        ]}
        rel="noopener"
        target="_blank"
      >
        {hostname(targetUrl)}
      </a>
    </blockquote>
  )}
  {entry.content && entry.type === 'reply' && (
    <Markdown content={linkifyHashtags(entry.content)} class="e-content" />
  )}
  <CardFooter detailUrl={detailUrl} pubDate={pubDate} />
</div>

<style>
  div {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .type-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-full);
  }

  .visibility-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-warning, #b58a00);
    background-color: color-mix(in oklch, var(--color-warning, #b58a00) 12%, transparent);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-full);
  }

  .visibility-badge :global(svg) {
    width: 0.7em;
    height: 0.7em;
  }

  .interaction-verb {
    font-style: italic;
  }

  blockquote {
    border-left: 3px solid var(--color-border-strong);
    padding: var(--space-2) var(--space-3);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background-color: var(--color-surface-2);
    font-style: normal;
  }

  blockquote a {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    text-decoration: none;
  }

  blockquote a:hover {
    text-decoration: underline;
  }
</style>
