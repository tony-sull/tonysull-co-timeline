---
import { Icon } from 'astro-icon/components';
import type { Entry, InteractionCounts } from '@indiepub/types';
import Markdown from '@indiepub/astro/components/Markdown.astro';
import VerbCallout from '../VerbCallout.astro';
import StarRating from '../StarRating.astro';
import CardFooter from '../CardFooter.astro';
import { linkifyHashtags } from '../../lib/format.ts';

interface Props {
  entry: Entry;
  counts?: InteractionCounts | undefined;
  detailUrl: string;
  pubDate: Date;
  badgeLabel?: string | undefined;
}

const { entry, counts, detailUrl, pubDate, badgeLabel } = Astro.props;
---

<div>
  <header>
    {badgeLabel && <span class="type-badge">{badgeLabel}</span>}
    {(entry.visibility === 'members' || entry.visibility === 'paid') && (
      <span class="visibility-badge">
        <Icon name="lock" aria-hidden="true" />
        {entry.visibility === 'paid' ? 'Paid' : 'Members'}
      </span>
    )}
  </header>
  <VerbCallout verb={entry.type} objectName={entry.objectName} objectUrl={entry.objectUrl} />
  {entry.rating != null && entry.rating > 0 && (
    <StarRating rating={entry.rating} />
  )}
  {entry.content && (
    <Markdown content={linkifyHashtags(entry.content)} class="e-content" />
  )}
  <CardFooter detailUrl={detailUrl} pubDate={pubDate} counts={counts} syndicationUrls={entry.syndicationUrls} />
</div>

<style>
  div {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .type-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-full);
  }

  .visibility-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25em;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-warning, #b58a00);
    background-color: color-mix(in oklch, var(--color-warning, #b58a00) 12%, transparent);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-full);
  }

  .visibility-badge :global(svg) {
    width: 0.7em;
    height: 0.7em;
  }
</style>
