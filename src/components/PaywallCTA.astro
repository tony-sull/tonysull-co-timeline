---
import { Icon } from 'astro-icon/components';
---

<div class="paywall-cta">
  <Icon name="lock" aria-hidden="true" />
  <p class="paywall-cta__heading">This post is for paid subscribers</p>
  <p class="paywall-cta__desc text-sm text-secondary">Upgrade your subscription to read the full article.</p>
  <a href="/subscribe">Subscribe</a>
</div>

<style>
  div {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-8) var(--space-6);
    background-color: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  div > :global(svg) {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--color-text-tertiary);
  }

  .paywall-cta__heading {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
  }

  a {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    background: var(--color-brand);
    color: var(--color-text-on-brand);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: background var(--transition);
  }

  a:hover {
    background: var(--color-text-link-hover);
    text-decoration: none;
  }
</style>
