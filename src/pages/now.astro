---
import Feed from '../layouts/Feed.astro';
import PostDetail from '../components/PostDetail.astro';
import { setCollectionCacheHeaders } from '../lib/cache';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { content } = Astro.locals.indiepub;
const entries = await content.getEntries('note', { tag: 'now', limit: 1 });
const nowEntry = entries[0] ?? null;

let interactions: import('@indiepub/types').Interaction[] = [];
let counts: import('@indiepub/types').InteractionCounts = { likes: 0, comments: 0, reposts: 0 };
let webmentions: import('@indiepub/types').WebMention[] = [];

if (nowEntry) {
  [interactions, counts, webmentions] = await Promise.all([
    content.getInteractions(nowEntry.id),
    content.getInteractionCounts(nowEntry.id),
    content.getWebmentions(nowEntry.id),
  ]);
}

setCollectionCacheHeaders(Astro.response, false, nowEntry ? [nowEntry] : []);
---

<Feed title="Now">
  <div class="now-page">
    <h1>Now</h1>

    {nowEntry ? (
      <PostDetail entry={nowEntry} webmentions={webmentions} interactions={interactions} counts={counts} />
    ) : (
      <div class="now-placeholder">
        <p>
          This is a <a href="https://nownownow.com/about" rel="noopener" target="_blank">/now page</a> —
          a snapshot of what's happening in the site owner's life right now.
        </p>
        <p>
          To update this page, publish a note and tag it with <strong>#now</strong>.
          The most recent <code>now</code>-tagged note will appear here automatically.
        </p>
      </div>
    )}
  </div>
</Feed>

<style>
  .now-page h1 {
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .now-placeholder {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background-color: var(--color-surface-2);
    border-radius: var(--radius-lg);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
  }
</style>
