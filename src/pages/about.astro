---
import { Icon } from 'astro-icon/components';
import Feed from '../layouts/Feed.astro';
import SocialIcon from '../components/SocialIcon.astro';
import { setStaticCacheHeaders } from '../lib/cache';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { content, config } = Astro.locals.indiepub;
const author = await content.getAuthor();

setStaticCacheHeaders(Astro.response);
---

<Feed title="About">
  <article class="about h-card">
    <!-- Avatar -->
    {author.photo && (
      <img
        class="u-photo about__avatar"
        src={author.photo}
        alt={author.name}
        width="96"
        height="96"
      />
    )}

    <!-- Identity -->
    <div class="about__identity">
      <h1 class="p-name about__name">{author.name}</h1>
      {author.url && (
        <a href={author.url} class="u-url about__url" rel="me">
          {new URL(author.url).hostname.replace(/^www\./, '')}
        </a>
      )}
      {author.bio && (
        <p class="p-note about__bio">{author.bio}</p>
      )}
    </div>

    <!-- Social links with rel=me -->
    {(author.socialLinks && author.socialLinks.length > 0) && (
      <nav class="about__social" aria-label="Social profiles">
        {author.socialLinks.map(link => (
          <a
            href={link.url}
            class="about__social-link u-url"
            rel="me noopener"
            target="_blank"
            aria-label={link.label}
          >
            <SocialIcon icon={link.icon} aria-hidden="true" />
            <span>{link.label}</span>
          </a>
        ))}
      </nav>
    )}

    <!-- Syndication profiles -->
    {(config?.syndication?.bluesky || config?.syndication?.mastodon) && (
      <section class="about__section" aria-labelledby="syndication-heading">
        <h2 id="syndication-heading">Find me on</h2>
        <ul class="about__link-list">
          {config.syndication.bluesky && (
            <li>
              <a
                href={`https://bsky.app/profile/${config.syndication.bluesky.handle}`}
                class="u-url"
                rel="me noopener"
                target="_blank"
              >
                <Icon name="social/bluesky" aria-hidden="true" />
                @{config.syndication.bluesky.handle}
              </a>
            </li>
          )}
          {config.syndication.mastodon && (
            <li>
              <a
                href={`https://${config.syndication.mastodon.instance}/@${config.syndication.mastodon.handle}`}
                class="u-url"
                rel="me noopener"
                target="_blank"
              >
                <Icon name="social/mastodon" aria-hidden="true" />
                @{config.syndication.mastodon.handle}@{config.syndication.mastodon.instance}
              </a>
            </li>
          )}
        </ul>
      </section>
    )}

    <!-- Feed links -->
    <section class="about__section" aria-labelledby="feeds-heading">
      <h2 id="feeds-heading">Subscribe</h2>
      <ul class="about__link-list">
        <li>
          <a href="/feed.xml">
            <Icon name="rss" aria-hidden="true" />
            RSS feed
          </a>
        </li>
        <li>
          <a href="/feed.atom">
            <Icon name="rss" aria-hidden="true" />
            Atom feed
          </a>
        </li>
        <li>
          <a href="/feed.json">
            <Icon name="rss" aria-hidden="true" />
            JSON Feed
          </a>
        </li>
      </ul>
      <p class="about__note text-sm text-secondary">
        <a href="https://en.wikipedia.org/wiki/Webmention">Webmentions</a> are supported.
        Built with <a href="https://indiepub.dev">IndiePub</a>.
      </p>
    </section>
  </article>
</Feed>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: var(--feed-max-width);
  }

  .about__avatar {
    width: 6rem;
    height: 6rem;
    border-radius: var(--radius-full);
    object-fit: cover;
  }

  .about__identity {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .about__name {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .about__url {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-family: var(--font-mono);
  }

  .about__url:hover {
    color: var(--color-text-link);
  }

  .about__bio {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 55ch;
  }

  /* Social links */
  .about__social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .about__social-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition), border-color var(--transition), background-color var(--transition);
  }

  .about__social-link:hover {
    color: var(--color-text-primary);
    border-color: var(--color-border-strong);
    background-color: var(--color-surface-2);
    text-decoration: none;
  }

  .about__social-link :global(svg) {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  /* Sections */
  .about__section {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .about__section h2 {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-tertiary);
  }

  .about__link-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .about__link-list a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-decoration: none;
  }

  .about__link-list a:hover {
    text-decoration: underline;
  }

  .about__link-list svg {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-text-tertiary);
  }

  .about__note {
    line-height: var(--leading-relaxed);
  }
</style>
