---
import Feed from '../layouts/Feed.astro';
import FeedCard from '../components/FeedCard.astro';
import NoteComposer from '../components/NoteComposer.astro';
import { setCollectionCacheHeaders } from '../lib/cache';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { content } = Astro.locals.indiepub;
const memberTier = Astro.locals.member?.tier ?? null;

const entries = await content.getEntries(undefined, { memberTier, limit: 50 });
const countsMap = await content.getBatchInteractionCounts(entries.map(e => e.id));

setCollectionCacheHeaders(Astro.response, !!Astro.locals.isAdmin, entries);
---

<Feed>
  <NoteComposer />
  <div class="h-feed feed-list" aria-label="All posts">
    {entries.length > 0 ? (
      entries.map(entry => <FeedCard entry={entry} counts={countsMap.get(entry.id)} />)
    ) : (
      <p class="empty-state text-secondary">No posts yet.</p>
    )}
  </div>
</Feed>

<style>
  .feed-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .empty-state {
    padding: var(--space-8) 0;
    text-align: center;
  }
</style>
