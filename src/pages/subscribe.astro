---
import Feed from '../layouts/Feed.astro';
import SubscribeForm from '../components/SubscribeForm.astro';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { config, content } = Astro.locals.indiepub;

// If subscriptions aren't enabled, 404
if (!config.subscriptions?.enabled) {
  return new Response('Not found', { status: 404 });
}

const subscriberCount = await content.getSubscriberCount();
---

<Feed title="Subscribe">
  <div class="subscribe-page">
    <h1 class="subscribe-page__title">Subscribe</h1>
    <p class="subscribe-page__desc">
      Get new posts delivered to your inbox. No spam, unsubscribe anytime.
    </p>
    {subscriberCount > 0 && (
      <p class="subscribe-page__count text-sm text-secondary">
        Join {subscriberCount} other {subscriberCount === 1 ? 'subscriber' : 'subscribers'}
      </p>
    )}
    <SubscribeForm />
  </div>
</Feed>

<style>
  .subscribe-page {
    max-width: 28rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6) 0;
  }

  .subscribe-page__title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
  }

  .subscribe-page__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
  }
</style>
