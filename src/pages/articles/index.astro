---
import { Icon } from 'astro-icon/components';
import Feed from '../../layouts/Feed.astro';
import { setCollectionCacheHeaders } from '../../lib/cache';

if (!Astro.locals.indiepub) {
  return new Response('Service unavailable', { status: 503 });
}

const { content } = Astro.locals.indiepub;
const memberTier = Astro.locals.member?.tier ?? null;
const articles = await content.getEntries('article', { memberTier, limit: 50 });
const countsMap = await content.getBatchInteractionCounts(articles.map(e => e.id));

setCollectionCacheHeaders(Astro.response, !!Astro.locals.isAdmin, articles);
---

<Feed title="Articles">
  <div class="page-heading">
    <h1>Articles</h1>
    <p class="text-secondary text-sm">Long-form writing.</p>
  </div>

  {articles.length > 0 ? (
    <ol class="article-list" reversed>
      {articles.map(entry => (
        <li class="article-item">
          <div class="article-item__date text-sm text-secondary">
            <time datetime={entry.publishedAt?.toISOString() ?? entry.createdAt.toISOString()}>
              {new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(
                entry.publishedAt ?? entry.createdAt
              )}
            </time>
          </div>
          <div class="article-item__body">
            <h2 class="article-item__title">
              <a href={`/posts/${entry.slug}`}>{entry.name}</a>
            </h2>
            {entry.summary && (
              <p class="article-item__summary text-sm text-secondary">{entry.summary}</p>
            )}
            {entry.tags && entry.tags.length > 0 && (
              <ul class="tag-list" aria-label="Tags">
                {entry.tags.map((tag: string) => (
                  <li>
                    <a href={`/tags/${encodeURIComponent(tag)}`} class="tag">#{tag}</a>
                  </li>
                ))}
              </ul>
            )}
            {(() => {
              const c = countsMap.get(entry.id);
              return c && (c.likes > 0 || c.reposts > 0 || c.comments > 0) ? (
                <div class="ix-bar">
                  {c.likes > 0 && <span class="ix-count"><Icon name="heart" aria-hidden="true" />{c.likes}</span>}
                  {c.reposts > 0 && <span class="ix-count"><Icon name="repeat-2" aria-hidden="true" />{c.reposts}</span>}
                  {c.comments > 0 && <span class="ix-count"><Icon name="message-square" aria-hidden="true" />{c.comments}</span>}
                </div>
              ) : null;
            })()}
          </div>
        </li>
      ))}
    </ol>
  ) : (
    <p class="empty-state text-secondary">No articles yet.</p>
  )}
</Feed>

<style>
  .page-heading {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-8);
  }

  .page-heading h1 {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
  }

  .article-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .article-item {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .article-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .article-item__date {
    padding-top: 0.25rem;
    flex-shrink: 0;
  }

  .article-item__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .article-item__title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
  }

  .article-item__title a {
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .article-item__title a:hover {
    color: var(--color-text-link);
    text-decoration: none;
  }

  .article-item__summary {
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    padding: 0;
  }

  .tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-link);
    background-color: var(--color-brand-muted);
    padding: 0.2em 0.6em;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background-color var(--transition);
  }

  .tag:hover {
    background-color: var(--color-surface-3);
    text-decoration: none;
  }

  .ix-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .ix-count {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .ix-count :global(svg) {
    width: 0.875rem;
    height: 0.875rem;
  }

  .empty-state {
    padding: var(--space-8) 0;
    text-align: center;
  }

  @media (max-width: 480px) {
    .article-item {
      grid-template-columns: 1fr;
      gap: var(--space-1);
    }
  }
</style>
