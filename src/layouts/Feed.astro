---
import Base from './Base.astro';
import SideProfile from '../components/SideProfile.astro';

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  canonicalUrl?: string | undefined;
  ogImage?: string | undefined;
}

const { title, description, canonicalUrl, ogImage } = Astro.props;

const indiepub = Astro.locals.indiepub;
const config = indiepub?.config;
const [author, topTags, nowEntries] = indiepub
  ? await Promise.all([
      indiepub.content.getAuthor(),
      indiepub.content.getTopTags(20),
      indiepub.content.getEntries('note', { tag: 'now', limit: 1 }),
    ])
  : [null, [], []];
const nowEntry = nowEntries[0] ?? null;
const activePath = Astro.url.pathname;
---

<Base title={title} description={description} canonicalUrl={canonicalUrl} ogImage={ogImage}>
  <!-- Mobile compact header -->
  <header class="mobile-header" id="mobile-header">
    <a href="/">{config?.title ?? 'My Site'}</a>
    <button
      id="hamburger-btn"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  <!-- Mobile menu overlay -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" aria-label="Navigation menu">
    {author && config && (
      <SideProfile author={author} config={config} activePath={activePath} topTags={topTags} nowEntry={nowEntry} mobile />
    )}
  </div>

  <!-- App shell -->
  <div class="app-layout">
    <!-- Desktop sidebar -->
    {author && config && (
      <aside class="app-sidebar">
        <SideProfile author={author} config={config} activePath={activePath} topTags={topTags} nowEntry={nowEntry} />
      </aside>
    )}

    <!-- Feed column -->
    <main class="app-main" id="main-content">
      <slot />
    </main>
  </div>
</Base>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.setAttribute('aria-hidden', String(expanded));
    menu?.classList.toggle('mobile-menu--open', !expanded);
    document.body.classList.toggle('menu-open', !expanded);
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (
      menu?.classList.contains('mobile-menu--open') &&
      !menu.contains(e.target as Node) &&
      !btn?.contains(e.target as Node)
    ) {
      btn?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.remove('mobile-menu--open');
      document.body.classList.remove('menu-open');
    }
  });
</script>

<style>
  /* ── Mobile header (< 768px only) ─────────────────────────── */
  .mobile-header {
    display: none;
    position: sticky;
    top: 0;
    z-index: 100;
    height: 3rem;
    padding: 0 var(--space-4);
    background-color: var(--color-surface-1);
    border-bottom: 1px solid var(--color-border);
    align-items: center;
    justify-content: space-between;
  }

  header a {
    font-weight: var(--weight-semibold);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  header a:hover {
    color: var(--color-text-link);
    text-decoration: none;
  }

  header button {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2rem;
    height: 2rem;
    padding: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: background-color var(--transition);
  }

  header button:hover {
    background-color: var(--color-surface-2);
  }

  header button span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text-primary);
    border-radius: 1px;
    transition: transform var(--transition), opacity var(--transition);
  }

  /* Mobile menu overlay */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 3rem;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 99;
    background-color: var(--color-surface-1);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    transform: translateY(-100%);
    opacity: 0;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .mobile-menu--open {
    transform: translateY(0);
    opacity: 1;
  }

  /* ── App shell ──────────────────────────────────────────────── */
  .app-layout {
    display: flex;
    justify-content: center;
    max-width: var(--app-max-width);
    margin-inline: auto;
    padding: var(--space-8) var(--space-4);
    gap: var(--space-8);
  }

  .app-sidebar {
    flex-shrink: 0;
    width: var(--sidebar-width);
  }

  .app-main {
    flex: 1;
    min-width: 0;
    max-width: var(--feed-max-width);
  }

  /* ── Mobile breakpoint ──────────────────────────────────────── */
  @media (max-width: 767px) {
    .mobile-header {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }

    .app-sidebar {
      display: none;
    }

    .app-layout {
      padding-top: var(--space-4);
    }
  }
</style>
